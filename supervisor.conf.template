; ── Cloudflare Tunnel — expose dashboard :8050 ───────────────────────────────
; Uses a quick tunnel (no account needed). URL changes on each restart.
; Find the URL: make tail-tunnel  (look for "trycloudflare.com" line)
[program:kronos-cloudflared]
command=/usr/local/bin/cloudflared tunnel --url http://localhost:8050
directory=__KRONOS_DIR__
autostart=true
autorestart=true
startsecs=5
startretries=5
stopwaitsecs=10
stopasgroup=true
killasgroup=true
priority=85
redirect_stderr=true
stdout_logfile=__LOG_DIR__/cloudflared.log
stdout_logfile_maxbytes=5MB
stdout_logfile_backups=3
