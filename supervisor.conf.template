; ─────────────────────────────────────────────────────────────────────────────
; Kronos Trading System — Supervisor program config
; Generated by install.sh from this template (paths are injected via sed).
; To regenerate after changing this file: bash install.sh
;
; Startup order (priority):
;   10  M01  data_collection      — WebSocket + OHLCV feed, must start first
;   20  M02  slippage_model       — passive scheduler, feeds risk checks
;   20  M03  macro_calendar       — passive scheduler, feeds risk checks
;   30  M05  risk_check           — gate before generators write signals
;   40  M13-M16  generators       — signal writers (need M01 data + M05 gate)
;   50  M06  execution            — order placer, needs signals in DB
;   50  M07  position_monitor     — stop/TP watcher, needs open trades
;   60  M08  portfolio_manager    — snapshot writer
;   60  M09  tax_tracker          — passive aggregator
;   60  M10  notification         — Telegram alerter
;   70  M11  health_monitor       — watchdog; starts last so targets are all up
;   80  M12  dashboard            — Flask UI; least critical
;   85  cloudflared              — Cloudflare quick tunnel → exposes :8050
;
; M04 (custom model) is HALTED — omitted. Add back if re-enabled.
;
; Program names for M01 and M02 MUST match KRONOS_SUPERVISORD_PREFIX + suffix
; used in 11_health_monitor.py _AUTO_RESTART_PROCESSES:
;   kronos-data-collection   (prefix=kronos-  suffix=data-collection)
;   kronos-slippage-model    (prefix=kronos-  suffix=slippage-model)
; ─────────────────────────────────────────────────────────────────────────────

[group:kronos]
programs=kronos-data-collection,kronos-slippage-model,kronos-macro-calendar,kronos-risk-check,kronos-mini-1h,kronos-base-1h,kronos-mini-4h,kronos-base-4h,kronos-execution,kronos-position-monitor,kronos-portfolio-manager,kronos-tax-tracker,kronos-notification,kronos-health-monitor,kronos-dashboard,kronos-cloudflared


; ── M01 — Data Collection ────────────────────────────────────────────────────
; Name must be: KRONOS_SUPERVISORD_PREFIX + "data-collection"  (M11 auto-restart)
[program:kronos-data-collection]
command=__KRONOS_DIR__/run_module.sh 01_data_collection.py
directory=__KRONOS_DIR__
autostart=true
autorestart=true
startsecs=10
startretries=5
stopwaitsecs=20
stopasgroup=true
killasgroup=true
priority=10
stdout_logfile=__LOG_DIR__/m01_data_collection.log
stdout_logfile_maxbytes=20MB
stdout_logfile_backups=5
stderr_logfile=__LOG_DIR__/m01_data_collection.err
stderr_logfile_maxbytes=10MB
stderr_logfile_backups=3


