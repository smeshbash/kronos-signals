# ─────────────────────────────────────────────────────────────────────────────
# Kronos Trading System — Environment Variables (Linux / Ubuntu LTS)
#
# Setup:
#   cp .env.example .env
#   nano .env          ← fill in the REQUIRED sections marked with ⚠
#
# This file is safe to commit (no secrets).
# .env is gitignored — your filled-in values stay local.
# ─────────────────────────────────────────────────────────────────────────────


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚠  REQUIRED — system will not start without these
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Exchange API (Delta Exchange India) ──────────────────────────────────────
#
# HOW TO GET YOUR API KEYS:
#  1. Log in to https://app.india.delta.exchange
#  2. Profile icon → API Keys → Create New API Key
#  3. Permissions:  ✅ Trade    ❌ Withdrawal (MUST be off)    ❌ Transfer
#  4. IP whitelist: set to this machine's public IP for security
#  5. Copy key + secret immediately — secret is shown only once
#
KRONOS_API_KEY=your_delta_api_key_here
KRONOS_API_SECRET=your_delta_api_secret_here

# ── Telegram notifications ────────────────────────────────────────────────────
#
# HOW TO SET UP:
#  1. Message @BotFather on Telegram → /newbot → follow prompts
#  2. Copy the bot token (format: 1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ)
#  3. Send any message to your new bot to activate the chat
#  4. Get your chat ID:
#       curl "https://api.telegram.org/bot<TOKEN>/getUpdates" | python3 -m json.tool
#     Look for: "chat": {"id": <YOUR_CHAT_ID>}
#
KRONOS_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
KRONOS_TELEGRAM_CHAT_ID=your_telegram_chat_id_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚠  REVIEW — defaults are safe but confirm before going live
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Trading mode ──────────────────────────────────────────────────────────────
# true  — paper trading, no real orders placed (safe default)
# false — LIVE trading. Only set after pre-live calibration (§20.5 Stage 2).
KRONOS_PAPER_MODE=true

# ── System phase ──────────────────────────────────────────────────────────────
# pre_live  — weeks 1-6, all signals logged, no confidence threshold
# income    — live trading, confidence threshold active, tax reserve maintained
# compound  — post-recuperation, full profit reinvestment
KRONOS_PHASE=pre_live

# ── USD/INR exchange rate ─────────────────────────────────────────────────────
# Used by M6, M7, M8, M9 for position sizing. Update weekly.
# Check current rate: https://www.google.com/search?q=usd+inr
KRONOS_USD_INR_RATE=84.0


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Portfolio parameters
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

KRONOS_STARTING_CAPITAL_INR=100000.0
# Fallback used by M6 when no portfolio snapshot exists yet.
KRONOS_PORTFOLIO_VALUE_INR=100000.0
# Monthly fixed costs charged to the portfolio (hosting, data feeds, etc.)
KRONOS_MONTHLY_FIXED_COSTS_INR=915.0


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Execution parameters
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Default leverage (max 3x, standard 2x per §8.1)
KRONOS_LEVERAGE=2.0
# Circuit breaker: reject signal if spread > this % of mark price (§8.4)
KRONOS_CB_SPREAD_PCT=1.0


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Regime filter (M5 risk check — Regime v4)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Composite EMA50/EMA200 on 4H candles, per symbol.
#   BEAR (close < EMA50 < EMA200) → longs blocked, shorts pass
#   BULL (close > EMA50 > EMA200) → shorts blocked, longs pass
#   NEUTRAL (disagreement)        → both directions pass
# Set to false only for backtesting or manual override.
KRONOS_REGIME_FILTER=true


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Model inference device
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# cpu  — default, safe for all hardware including Optimus (Intel + NVIDIA MX)
#         No CUDA drivers required. 4H/1H inference takes < 1s on i5 8th gen.
# cuda — GPU inference. Requires:
#           sudo apt install nvidia-driver-535
#           reboot
#           bash install.sh --cuda   (reinstalls PyTorch with CUDA 12.1)
KRONOS_SHADOW_DEVICE=cpu


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# File paths  (relative to project root — do not change unless you move data/)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

KRONOS_DB_PATH=./data/kronos.db
KRONOS_MODEL_PATH=./models/kronos_model.pt
KRONOS_MACRO_CALENDAR=./macro_calendar.json
KRONOS_NOTIFIER_STATE_PATH=./data/notifier_state.json


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Kronos foundation model parameters
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Lookback window in 4H candles (96 = 16 days)
KRONOS_SEQ_LEN=96
# Forecast horizon in 4H candles (6 = 24H forward)
KRONOS_PRED_LEN=6
# Anomaly gate: reject signal if predicted return > this % (§19.1 item 4)
KRONOS_MAX_PRED_RETURN=20.0


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Dashboard (M12 — Flask)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Port for the Flask dashboard. Open this in your firewall if accessing remotely:
#   sudo ufw allow 8050/tcp
KRONOS_DASHBOARD_PORT=8050


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Supervisor integration (M11 health monitor)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# CRITICAL: must match the [program:...] names in supervisor.conf.template.
# M11 calls: supervisorctl restart <prefix>data-collection
#                                  <prefix>slippage-model
# Do NOT change this unless you also rename the programs in supervisor.conf.template.
KRONOS_SUPERVISORD_PREFIX=kronos-


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Email alerts (backup to Telegram — optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# HOW TO GET GMAIL APP PASSWORD:
#  1. Enable 2FA on your Gmail account (required)
#  2. Go to: https://myaccount.google.com/apppasswords
#  3. App: Mail  /  Device: Other (name it "Kronos")
#  4. Copy the 16-character password — no spaces
#
KRONOS_EMAIL_FROM=your_gmail_address@gmail.com
KRONOS_EMAIL_TO=your_alert_recipient@gmail.com
KRONOS_EMAIL_APP_PASSWORD=your_16_char_app_password_here


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Health monitor thresholds — optional overrides (defaults shown)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Uncomment and adjust only if you need to tune alert sensitivity.
# KRONOS_HM_HEARTBEAT_STALE_S=1800    # 30 min  — M1 data freshness
# KRONOS_HM_SLIPPAGE_STALE_S=1800     # 30 min  — M2 slippage model freshness
# KRONOS_HM_PORTFOLIO_STALE_S=18000   # 5 hours — M8 snapshot freshness
# KRONOS_HM_NOTIFIER_STALE_S=1800     # 30 min  — M10 cursor freshness
# KRONOS_HM_ORPHAN_STALE_S=18000      # 5 hours — open trade with no position row
# KRONOS_HM_FO_WINDOW_S=86400         # 24 hours — forced override frequency window
# KRONOS_HM_FO_MAX=3                  # 3 forced overrides in 24H → health_error
